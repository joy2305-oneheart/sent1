# wp-content deploy repo — track custom code only.
# Initialize git here, then push to your server's wp-content directory.

# Ignore everything at wp-content root by default
/*
!/.gitignore

# Must-use plugins
!/mu-plugins/
!/mu-plugins/**

# Custom plugins only
!/plugins/
/plugins/*
!/plugins/social-invite-network/
!/plugins/social-invite-network/**
!/plugins/sent-one-social-login/
!/plugins/sent-one-social-login/**

# Custom themes only
!/themes/
/themes/*
!/themes/one-1/
!/themes/one-1/**
!/themes/twentytwentyfive/
!/themes/twentytwentyfive/**

# Never deploy these (explicit for clarity)
/uploads/
/upgrade/
/upgrade-temp-backup/
*.zip
.DS_Store
Thumbs.db
